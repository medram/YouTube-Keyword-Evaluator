# ─────────────────────────────────────────────────────────────────────────────
#  YouTube Keyword Evaluator — Environment Variables
# ─────────────────────────────────────────────────────────────────────────────
#
#  Copy this file to .env and fill in your values:
#      cp .env.example .env
#
#  .env is gitignored — never commit your real API key.
# ─────────────────────────────────────────────────────────────────────────────


# ── YouTube Data API v3 ──────────────────────────────────────────────────────
# Required for the REST API and MCP server.
# Get a free key at: https://console.cloud.google.com/
#   → Create / select a project
#   → APIs & Services → Enable → search "YouTube Data API v3"
#   → Credentials → Create API Key
#
# Free quota: ~10,000 units/day  (~1,000–1,600 keyword analyses)
# Each keyword analysis uses ~6–10 quota units.

YOUTUBE_API_KEY=AIzaSy...your_key_here


# ── REST API (api.py) ────────────────────────────────────────────────────────

API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=1
API_RELOAD=true
API_LOG_LEVEL=info


# ── MCP Server (mcp_server.py) ───────────────────────────────────────────────

MCP_HOST=0.0.0.0
MCP_PORT=8001
